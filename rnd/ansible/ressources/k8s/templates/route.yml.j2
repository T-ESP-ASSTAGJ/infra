{% if route.type == 'TCPRoute' %}
apiVersion: gateway.networking.k8s.io/v1alpha2
kind: TCPRoute
metadata:
  name: {{ route.name }}
  namespace: {{ gateway.namespace }}
  annotations:
    konghq.com/plugins: prometheus-{{ gateway.namespace }}
spec:
  parentRefs:
  - name: {{ gateway.name }}-gateway
    namespace: {{ gateway.namespace }}
    sectionName: "{{ route.parent_listener }}"
  rules:
    - backendRefs:
{% for backend in route.backends %}
      - name: {{ backend.name }}
        kind: {{ backend.kind | default('Service') }}
        port: {{ backend.port }}
        namespace: {{ backend.namespace }}
{% endfor %}
{% elif route.type == 'HTTPRoute' %}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ route.name }}
  namespace: {{ gateway.namespace }}
  annotations:
    konghq.com/plugins: prometheus-{{ gateway.namespace }}
spec:
  parentRefs:
  - name: {{ gateway.name }}-gateway
    namespace: {{ gateway.namespace }}
    sectionName: {{ route.parent_listener }}
  rules:
  - matches: # The single rule object (list item) starts here
{% for path in route.match_path %}
    - path:
        type: PathPrefix
        value: "{{ path }}"
{% endfor %}
{% if route.rewrite_path == true %}
    filters:
    - type: URLRewrite
      urlRewrite:
        path:
          type: ReplacePrefixMatch
          replacePrefixMatch: /
{% endif %}
    backendRefs: 
{% for backend in route.backends %}
    - name: {{ backend.name }}
      kind: {{ backend.kind | default('Service') }}
      port: {{ backend.port }}
      namespace: {{ backend.namespace }}
{% endfor %}
{% endif %}