apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: cert-manager-sa-token-creator
  namespace: {{ issuer.namespace }} 
rules:
  - apiGroups: [""]
    resources: ["serviceaccounts/token"]
    verbs: ["create"]

---

apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: cert-manager-sa-token-creator-binding
  namespace: {{ issuer.namespace }} 
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: cert-manager-sa-token-creator
subjects:
  - kind: ServiceAccount
    name: {{ issuer.cert_manager_service_account }}
    namespace: {{ issuer.cert_manager_namespace }}
