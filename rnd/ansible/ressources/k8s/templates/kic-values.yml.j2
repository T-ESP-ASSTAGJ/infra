# Combined values for Kong Gateway and Ingress Controller Helm Chart.
# This file configures a single release to deploy both components.

# -----------------------------------------------------------------------------
# Deployment parameters
# -----------------------------------------------------------------------------
deployment:
  # Kong Gateway deployment is enabled.
  kong:
    enabled: true
  # The number of old `ReplicaSet`s to retain.
  revisionHistoryLimit: 10
  # Specify the service account to create and to be assigned to the deployment.
  serviceAccount:
    create: true
    automountServiceAccountToken: false

# -----------------------------------------------------------------------------
# Kong Gateway parameters
# -----------------------------------------------------------------------------
env:
  KONG_PLUGINS: "bundled,oidc,jwt-keycloak"
  KONG_LOG_LEVEL: "debug"
  database: "off"
  router_flavor: "traditional"
  nginx_worker_processes: "2"
  proxy_access_log: /dev/stdout
  admin_access_log: /dev/stdout
  proxy_error_log: /dev/stderr
  admin_error_log: /dev/stderr
  prefix: /kong_prefix/

extraLabels: {}

image:
  repository: ghcr.io/example/kong-oidc
  tag: "4.0.0"
  pullPolicy: IfNotPresent

# Kong Admin API Service configuration
admin:
  enabled: true
  type: NodePort
  http:
    enabled: false
  tls:
    enabled: true
    servicePort: 8444
    containerPort: 8444
    parameters:
      - http2

# Specify Kong status listener configuration
# This listen is internal-only. It cannot be exposed through a service or ingress.
status:
  enabled: true
  http:
    # Enable plaintext HTTP listen for the status listen
    enabled: false
    containerPort: 8100
    parameters: []

  tls:
    # Enable HTTPS listen for the status listen
    # Kong versions prior to 2.1 do not support TLS status listens.
    # This setting must remain false on those versions
    enabled: true
    containerPort: 8543
    parameters: []

# This Jinja templating is preserved from your original files.
# It dynamically configures listeners based on the 'gateway' variable from Ansible.
{% set http_listeners = gateway.listeners | selectattr('protocol', 'equalto', 'HTTP') | list %}
{% set https_listeners = gateway.listeners | selectattr('protocol', 'equalto', 'HTTPS') | list %}
{% set tcp_listeners = gateway.listeners | selectattr('protocol', 'in', ['TLS','TCP']) | list %}
{% set udp_listeners = gateway.listeners | selectattr('protocol', 'equalto', 'UDP') | list %}

# Kong Proxy Service configuration
proxy:
  enabled: true
  type: LoadBalancer
  annotations: {}
  labels:
    enable-metrics: "true"

  http:
{% if http_listeners %}
    enabled: true
    servicePort: {{ http_listeners[0].port }}
    containerPort: 8000
{% else %}
    enabled: false
{% endif %}

  tls:
{% if https_listeners %}
    enabled: true
    servicePort: {{ https_listeners[0].port }}
    containerPort: 8443
    parameters:
      - http2
{% else %}
    enabled: false
{% endif %}
  
  stream:
{% for listener in tcp_listeners %}
  - containerPort: {{ listener.port }}
    servicePort: {{ listener.port }}
    protocol: TCP
{% if listener.protocol == 'TLS' %}
    parameters:
      - ssl
{% endif %}
{% endfor %}

udpProxy:
{% if udp_listeners %}
  enabled: true
  type: LoadBalancer
  annotations: {}
  labels: {}
  stream:
{% for listener in udp_listeners %}
  - containerPort: {{ listener.port }}
    servicePort: {{ listener.port }}
    protocol: UDP
{% endfor %}
{% else %}
  enabled: false
{% endif %}

secretVolumes: []

# -----------------------------------------------------------------------------
# Ingress Controller parameters
# -----------------------------------------------------------------------------
ingressController:
  # Ingress Controller deployment is enabled.
  enabled: true
  image:
    repository: kong/kubernetes-ingress-controller
    tag: "3.5"

  # Automatically discover the admin API service of the gateway in this release.
  gatewayDiscovery:
    enabled: false
    # The admin service is generated by the gateway deployment, so we don't need another one.
    generateAdminApiService: false
    adminApiService:
      # This should point to the namespace where this combined chart is deployed.
      namespace: "{{ gateway.namespace }}"
      # This should be the name of the Admin API service created above.
      name: "{{ gateway.name }}-gateway-kong-admin"

  # Watch for resources only in the specified namespace.
  watchNamespaces:
    - "{{ gateway.namespace }}"

  env:
    gateway_api_controller_name: "konghq.com/{{ gateway.name }}-controller"
    kong_admin_tls_skip_verify: false
    TZ: "Europe/Paris"

  admissionWebhook:
    enabled: true
    failurePolicy: Ignore
    port: 8080

  ingressClass: kong

  rbac:
    create: true
    enableClusterRoles: true
    gatewayAPI:
      enabled: true

  # Probes for the Ingress Controller container.
  livenessProbe:
    httpGet:
      path: "/healthz"
      port: 10254
      scheme: HTTP
    initialDelaySeconds: 5
    timeoutSeconds: 5
    periodSeconds: 10
    successThreshold: 1
    failureThreshold: 3
  readinessProbe:
    httpGet:
      path: "/readyz"
      port: 10254
      scheme: HTTP
    initialDelaySeconds: 5
    timeoutSeconds: 5
    periodSeconds: 10
    successThreshold: 1
    failureThreshold: 3

  # Resource requests/limits for the controller container.
  resources: {}
  #   requests:
  #     cpu: 50m
  #     memory: 128Mi

  # mTLS configuration for the controller to securely connect to the gateway's Admin API.
  adminApi:
    tls:
      client:
        enabled: true
        certProvided: true
        secretName: "{{ gateway.controller_client_certificate_name }}"
        caSecretName: "{{ gateway.controller_client_ca_name }}"
        

# -----------------------------------------------------------------------------
# Configure cert-manager integration
# -----------------------------------------------------------------------------

certificates:
  enabled: true

  # Set the certificate timers or leave on the default value
  # Default is 15 days
  renewBefore: "360h0m0s"
  # Default is 90d days
  duration: "2160h0m0s"
  # Set either `issuer` or `clusterIssuer` to the name of the desired cert manager issuer
  # If left blank a built in self-signed issuer will be created and utilized
  issuer: "kong-database-gateway-issuer"
  clusterIssuer: ""

  # Set proxy.enabled to true to issue default kong-proxy certificate with cert-manager
  proxy:
    enabled: false
    # Set `issuer` or `clusterIssuer` to name of alternate cert-manager clusterIssuer to override default
    # self-signed issuer.
    issuer: ""
    clusterIssuer: ""
    # Use commonName and dnsNames to set the common name and dns alt names which this
    # certificate is valid for. Wildcard records are supported by the included self-signed issuer.
    commonName: "app.example"
    # Remove the "[]" and uncomment/change the examples to add SANs
    dnsNames: []
    # - "app.example"
    # - "*.apps.example"
    # - "*.kong.example"

  # Set admin.enabled true to issue kong admin api and manager certificate with cert-manager
  admin:
    enabled: false
    # Set `issuer` or `clusterIssuer` to name of alternate cert-manager clusterIssuer to override default
    # self-signed issuer.
    issuer: "kong-database-gateway-issuer"
    clusterIssuer: ""
    # Use commonName and dnsNames to set the common name and dns alt names which this
    # certificate is valid for. Wildcard records are supported by the included self-signed issuer.
    commonName: "kong.example"
    # Remove the "[]" and uncomment/change the examples to add SANs
    dnsNames: []
    # - "manager.kong.example"

  # Set portal.enabled to true to issue a developer portal certificate with cert-manager
  portal:
    enabled: false
    # Set `issuer` or `clusterIssuer` to name of alternate cert-manager clusterIssuer to override default
    # self-signed issuer.
    issuer: ""
    clusterIssuer: ""
    # Use commonName and dnsNames to set the common name and dns alt names which this
    # certificate is valid for. Wildcard records are supported by the included self-signed issuer.
    commonName: "developer.example"
    # Remove the "{}" and uncomment/change the examples to add SANs
    dnsNames: []
    # - "manager.kong.example"

  # Set cluster.enabled true to issue kong hybrid mtls certificate with cert-manager
  cluster:
    enabled: false
    # Issuers used by the control and data plane releases must match for this certificate.
    issuer: ""
    clusterIssuer: ""
    commonName: "kong_clustering"
    dnsNames: []

# -----------------------------------------------------------------------------
# Miscellaneous parameters (shared)
# -----------------------------------------------------------------------------
replicaCount: 1

readinessProbe:
  httpGet:
    path: "/status" # Using /status to break startup deadlocks.
    port: 8100      # <-- FIXED: Using explicit port number
    scheme: HTTP
  initialDelaySeconds: 5
  timeoutSeconds: 5
  periodSeconds: 10
  successThreshold: 1
  failureThreshold: 3

livenessProbe:
  httpGet:
    path: "/status"
    port: 8100      # <-- FIXED: Using explicit port number
    scheme: HTTP
  initialDelaySeconds: 5
  timeoutSeconds: 5
  periodSeconds: 10
  successThreshold: 1
  failureThreshold: 3

# Resource requests/limits for the Kong Gateway container.
resources: {}
  # requests:
  #  cpu: 1
#  memory: 2G

terminationGracePeriodSeconds: 30
tolerations: []
nodeSelector: {}

podAnnotations:
  kuma.io/gateway: enabled
  traffic.sidecar.istio.io/includeInboundPorts: ""

podLabels: {}
priorityClassName: ""

securityContext:
  seccompProfile:
    type: RuntimeDefault

containerSecurityContext:
  readOnlyRootFilesystem: true
  allowPrivilegeEscalation: false
  runAsUser: 1000
  runAsGroup: 1000
  runAsNonRoot: true
  seccompProfile:
    type: RuntimeDefault
  capabilities:
    drop:
      - ALL

serviceMonitor:
  enabled: true
